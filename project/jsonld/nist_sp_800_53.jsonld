      "definition_uri": "https://w3id.org/lmodel/nist-sp-800-53/NistSp80053r5Cprt",
      "description": "NIST CPRT (Cybersecurity and Privacy Reference Tool) export subset covering SP 800-53, SP 800-53A, and SP 800-53B element and relationship data",
      "from_schema": "https://w3id.org/lmodel/nist-sp-800-53",
      "@type": "SubsetDefinition"
    }
  ],
