      "@type": "SubsetDefinition"
    },
    {
      "name": "nist_sp_800_53r5_profile",
      "definition_uri": "https://w3id.org/lmodel/nist-sp-800-53/NistSp80053r5Profile",
      "description": "NIST SP 800-53 Rev 5 profile subset for baselines and overlays",
      "from_schema": "https://w3id.org/lmodel/nist-sp-800-53",
      "@type": "SubsetDefinition"
    },
    {
      "name": "nist_sp_800_53r4_catalog",
      "definition_uri": "https://w3id.org/lmodel/nist-sp-800-53/NistSp80053r4Catalog",
      "description": "NIST SP 800-53 Rev 4 backward-compatibility subset for catalog elements present in OSCAL 1.2.x representations but removed in Rev 5 (e.g. depends-on parameter dependency)",
      "from_schema": "https://w3id.org/lmodel/nist-sp-800-53",
      "@type": "SubsetDefinition"
    },
    {
