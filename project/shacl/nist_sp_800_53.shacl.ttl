@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

linkml:Any a sh:NodeShape ;
    rdfs:comment "A configurable parameter used by a control",
        "Alteration to a referenced control — adds or removes parts",
        "Assignment of parties to a role",
        "CPRT API response container holding document metadata, typed elements (controls, enhancements, ODPs, assessment objectives, baselines), relationship types, and element relationships",
        "Citation wrapper",
        "Content to be added to a control via profile alteration",
        "Control inclusion selector",
        "Glob or regex pattern for selecting controls by identifier",
        "Imported profile or catalog reference",
        "Main catalog object",
        "Marker object indicating flat merge strategy for profile resolution",
        "Merge configuration",
        "Metadata revision entry",
        "OSCAL back-matter section",
        "OSCAL metadata section used in catalogs and profiles",
        "OSCAL profile body",
        "Override the value of a parameter in a referenced control",
        "Party definition",
        "Postal address",
        "Profile modification section containing parameter overrides and control alterations",
        "Reference link for a resource",
        "Referenced resource",
        "Selection criteria for a parameter",
        "Selection of controls to explicitly exclude from a profile import",
        "Semantic class for NIST CPRT (Cybersecurity and Privacy Reference Tool) export documents covering SP 800-53, SP 800-53A, and SP 800-53B. Validate with: linkml validate -C SP80053Document -s <schema> <file.json>",
        "Unified root wrapper for catalog, profile, or CPRT content" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ) ;
    sh:property [ sh:description "Include-controls selectors" ;
            sh:order 1 ;
            sh:path nist_sp_800_53:include_controls ],
        [ sh:datatype xsd:string ;
            sh:description "Party type" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_53:type ],
        [ sh:datatype xsd:string ;
            sh:description "Link or resource reference" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_53:href ],
        [ sh:description "Profile and Catalog metadata" ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nist_sp_800_53:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "Referenced party UUIDs" ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_53:party_uuids ],
        [ sh:description "Pattern-based control selectors using glob or regex patterns" ;
            sh:order 1 ;
            sh:path nist_sp_800_53:matching ],
        [ sh:description "Imported catalogs or profiles" ;
            sh:order 2 ;
            sh:path nist_sp_800_53:imports ],
        [ sh:description "Back-matter resources" ;
            sh:order 0 ;
            sh:path nist_sp_800_53:resources ],
        [ sh:description "Flat merge strategy — de-duplicate and merge all controls without source hierarchy" ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nist_sp_800_53:flat ],
        [ sh:datatype xsd:string ;
            sh:description "Postal code" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_53:postal_code ],
        [ sh:description "Merge behavior settings" ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path nist_sp_800_53:merge ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_53:title ],
        [ sh:datatype xsd:string ;
            sh:description "Last modification timestamp" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_53:last_modified ],
        [ sh:description "Responsible party assignments" ;
