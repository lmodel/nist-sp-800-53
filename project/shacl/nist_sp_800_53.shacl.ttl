            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path nist_sp_800_53:remarks ],
        [ sh:description "Metadata revisions" ;
            sh:order 4 ;
            sh:path nist_sp_800_53:revisions ],
        [ sh:description "Selection parameters for a parameter definition" ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nist_sp_800_53:select ],
        [ sh:datatype xsd:string ;
            sh:description "Media type for a resource link" ;
