            sh:order 1 ;
            sh:path nist_sp_800_53:choice ],
        [ sh:description "Profile and Catalog metadata" ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nist_sp_800_53:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
