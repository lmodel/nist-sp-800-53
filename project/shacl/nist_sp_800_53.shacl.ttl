            sh:order 2 ;
            sh:path nist_sp_800_53:title ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path nist_sp_800_53:label ],
        [ sh:class nist_sp_800_53:ControlEnhancement ;
            sh:description "List of controls in a group" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path nist_sp_800_53:controls ],
        [ sh:class nist_sp_800_53:Part ;
