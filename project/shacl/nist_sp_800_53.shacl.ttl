nist_sp_800_53:Catalog a sh:NodeShape ;
    rdfs:comment "Top-level wrapper that mirrors OSCAL catalog shape" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Root catalog payload" ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path nist_sp_800_53:catalog ] ;
    sh:targetClass nist_sp_800_53:Catalog .

nist_sp_800_53:CatalogElement a sh:NodeShape ;
    rdfs:comment "Base class for catalog elements" ;
    sh:closed false ;
    sh:ignoredProperties ( nist_sp_800_53:_class nist_sp_800_53:controls nist_sp_800_53:params nist_sp_800_53:name nist_sp_800_53:select nist_sp_800_53:label nist_sp_800_53:depends_on nist_sp_800_53:title nist_sp_800_53:prose rdf:type nist_sp_800_53:guidelines nist_sp_800_53:groups ) ;
    sh:property [ sh:class nist_sp_800_53:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path nist_sp_800_53:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_53:id ],
        [ sh:class nist_sp_800_53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nist_sp_800_53:links ],
        [ sh:class nist_sp_800_53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path nist_sp_800_53:props ] ;
    sh:targetClass nist_sp_800_53:CatalogElement .

nist_sp_800_53:IdentifiedElement a sh:NodeShape ;
    rdfs:comment "A catalog element with required id and optional title/class" ;
    sh:closed true ;
    sh:ignoredProperties ( nist_sp_800_53:controls nist_sp_800_53:params nist_sp_800_53:name nist_sp_800_53:select nist_sp_800_53:prose nist_sp_800_53:depends_on rdf:type nist_sp_800_53:guidelines nist_sp_800_53:groups ) ;
    sh:property [ sh:class nist_sp_800_53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_53:links ],
        [ sh:class nist_sp_800_53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path nist_sp_800_53:props ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_53:id ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_53:label ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_53:title ],
        [ sh:description "Classification of a catalog element or property" ;
            sh:in ( "family" "SP800-53" "SP800-53-enhancement" "assessment-objective" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nist_sp_800_53:_class ],
        [ sh:class nist_sp_800_53:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path nist_sp_800_53:parts ] ;
    sh:targetClass nist_sp_800_53:IdentifiedElement .

nist_sp_800_53:ProfileDocument a sh:NodeShape ;
    rdfs:comment "Top-level wrapper for OSCAL profile files" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Root profile payload" ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path nist_sp_800_53:profile ] ;
    sh:targetClass nist_sp_800_53:ProfileDocument .

nist_sp_800_53:Control a sh:NodeShape ;
    rdfs:comment "A security control" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Classification of a catalog element or property" ;
            sh:in ( "family" "SP800-53" "SP800-53-enhancement" "assessment-objective" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path nist_sp_800_53:_class ],
        [ sh:class nist_sp_800_53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
