            sh:order 1 ;
            sh:path nist_sp_800_53:title ],
        [ sh:description "Parties used in metadata" ;
            sh:order 8 ;
            sh:path nist_sp_800_53:parties ],
        [ sh:description "Parameter value overrides applied by the profile" ;
            sh:order 0 ;
            sh:path nist_sp_800_53:set_parameters ],
