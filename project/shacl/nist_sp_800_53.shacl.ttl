@prefix linkml: <https://w3id.org/linkml/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sp-800-53: <https://w3id.org/lmodel/nist-sp-800-53/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sp-800-53:Catalog a sh:NodeShape ;
    rdfs:comment "Top-level wrapper that mirrors OSCAL catalog shape" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class linkml:Any ;
            sh:description "Root catalog payload" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path sp-800-53:catalog ] ;
    sh:targetClass sp-800-53:Catalog .

sp-800-53:CatalogElement a sh:NodeShape ;
    rdfs:comment "Base class for catalog elements" ;
    sh:closed false ;
    sh:ignoredProperties ( sp-800-53:title sp-800-53:label sp-800-53:controls sp-800-53:name sp-800-53:select rdf:type sp-800-53:prose sp-800-53:class sp-800-53:guidelines sp-800-53:params ) ;
    sh:property [ sh:class sp-800-53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path sp-800-53:props ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:id ],
        [ sh:class sp-800-53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path sp-800-53:links ],
        [ sh:class sp-800-53:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path sp-800-53:parts ] ;
    sh:targetClass sp-800-53:CatalogElement .

sp-800-53:IdentifiedElement a sh:NodeShape ;
    rdfs:comment "A catalog element with required id and optional title/class" ;
    sh:closed true ;
    sh:ignoredProperties ( sp-800-53:controls sp-800-53:name sp-800-53:select rdf:type sp-800-53:prose sp-800-53:guidelines sp-800-53:params ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path sp-800-53:id ],
        [ sh:class sp-800-53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path sp-800-53:links ],
        [ sh:description "Classification of a catalog element or property" ;
            sh:in ( "family" "SP800-53" "SP800-53-enhancement" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path sp-800-53:class ],
        [ sh:class sp-800-53:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path sp-800-53:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path sp-800-53:label ],
        [ sh:class sp-800-53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path sp-800-53:props ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:title ] ;
    sh:targetClass sp-800-53:IdentifiedElement .

sp-800-53:ProfileDocument a sh:NodeShape ;
    rdfs:comment "Top-level wrapper for OSCAL profile files" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class linkml:Any ;
            sh:description "Root profile payload" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path sp-800-53:profile ] ;
    sh:targetClass sp-800-53:ProfileDocument .

sp-800-53:Control a sh:NodeShape ;
    rdfs:comment "A security control" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class sp-800-53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path sp-800-53:links ],
        [ sh:description "Classification of a catalog element or property" ;
            sh:in ( "family" "SP800-53" "SP800-53-enhancement" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path sp-800-53:class ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path sp-800-53:label ],
        [ sh:class sp-800-53:Parameter ;
            sh:description "List of parameters for a control" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path sp-800-53:params ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path sp-800-53:title ],
        [ sh:class sp-800-53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path sp-800-53:props ],
        [ sh:class sp-800-53:ControlEnhancement ;
            sh:description "List of controls in a group" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path sp-800-53:controls ],
        [ sh:class sp-800-53:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path sp-800-53:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path sp-800-53:id ] ;
    sh:targetClass sp-800-53:Control .

sp-800-53:ControlGroup a sh:NodeShape ;
    rdfs:comment "A group of controls (family)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Classification of a catalog element or property" ;
            sh:in ( "family" "SP800-53" "SP800-53-enhancement" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path sp-800-53:class ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path sp-800-53:id ],
        [ sh:class sp-800-53:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path sp-800-53:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path sp-800-53:title ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path sp-800-53:label ],
        [ sh:class sp-800-53:Control ;
            sh:description "List of controls in a group" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path sp-800-53:controls ],
        [ sh:class sp-800-53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path sp-800-53:links ],
        [ sh:class sp-800-53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path sp-800-53:props ] ;
    sh:targetClass sp-800-53:ControlGroup .

sp-800-53:Guideline a sh:NodeShape ;
    rdfs:comment "Additional prose guidance associated with a parameter" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text prose content" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:prose ] ;
    sh:targetClass sp-800-53:Guideline .

sp-800-53:Role a sh:NodeShape ;
    rdfs:comment "Role definition" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path sp-800-53:title ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:id ] ;
    sh:targetClass sp-800-53:Role .

sp-800-53:ControlEnhancement a sh:NodeShape ;
    rdfs:comment "An enhancement to a control" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class sp-800-53:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path sp-800-53:parts ],
        [ sh:class sp-800-53:Parameter ;
            sh:description "List of parameters for a control" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path sp-800-53:params ],
        [ sh:class sp-800-53:ControlEnhancement ;
            sh:description "List of controls in a group" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path sp-800-53:controls ],
        [ sh:class sp-800-53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path sp-800-53:props ],
        [ sh:class sp-800-53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path sp-800-53:links ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path sp-800-53:title ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path sp-800-53:id ],
        [ sh:description "Classification of a catalog element or property" ;
            sh:in ( "family" "SP800-53" "SP800-53-enhancement" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path sp-800-53:class ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path sp-800-53:label ] ;
    sh:targetClass sp-800-53:ControlEnhancement .

sp-800-53:Parameter a sh:NodeShape ;
    rdfs:comment "A configurable parameter used by a control" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class sp-800-53:Guideline ;
            sh:description "List of guidelines" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path sp-800-53:guidelines ],
        [ sh:class sp-800-53:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path sp-800-53:parts ],
        [ sh:class sp-800-53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path sp-800-53:props ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path sp-800-53:label ],
        [ sh:description "Classification of a catalog element or property" ;
            sh:in ( "family" "SP800-53" "SP800-53-enhancement" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path sp-800-53:class ],
        [ sh:class sp-800-53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path sp-800-53:links ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path sp-800-53:id ],
        [ sh:class linkml:Any ;
            sh:description "Selection parameters for a parameter definition" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path sp-800-53:select ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path sp-800-53:title ] ;
    sh:targetClass sp-800-53:Parameter .

sp-800-53:Part a sh:NodeShape ;
    rdfs:comment "Structured narrative part that can contain nested parts" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path sp-800-53:label ],
        [ sh:datatype xsd:string ;
            sh:description "Name of a property, part, or party" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:name ],
        [ sh:class sp-800-53:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path sp-800-53:props ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path sp-800-53:id ],
        [ sh:class sp-800-53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path sp-800-53:links ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path sp-800-53:title ],
        [ sh:class sp-800-53:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path sp-800-53:parts ],
        [ sh:description "Classification of a catalog element or property" ;
            sh:in ( "family" "SP800-53" "SP800-53-enhancement" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path sp-800-53:class ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text prose content" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path sp-800-53:prose ] ;
    sh:targetClass sp-800-53:Part .

sp-800-53:Property a sh:NodeShape ;
    rdfs:comment "A name-value property with optional namespace and class attributes" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Name of a property, part, or party" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:name ],
        [ sh:description "Classification of a catalog element or property" ;
            sh:in ( "sp800-53" "sp800-53a" "zero-padded" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path sp-800-53:class ],
        [ sh:datatype xsd:string ;
            sh:description "Property value" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path sp-800-53:value ],
        [ sh:datatype xsd:string ;
            sh:description "Namespace URI for a property" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path sp-800-53:ns ] ;
    sh:targetClass sp-800-53:Property .

sp-800-53:Link a sh:NodeShape ;
    rdfs:comment "Relationship link" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Relationship type for a link" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path sp-800-53:rel ],
        [ sh:datatype xsd:string ;
            sh:description "Link or resource reference" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:href ] ;
    sh:targetClass sp-800-53:Link .

linkml:Any a sh:NodeShape ;
    rdfs:comment "Assignment of parties to a role",
        "Citation wrapper",
        "Control inclusion selector",
        "Imported profile or catalog reference",
        "Main catalog object",
        "Merge configuration",
        "Metadata revision entry",
        "OSCAL back-matter section",
        "OSCAL metadata section used in catalogs and profiles",
        "OSCAL profile body",
        "Party definition",
        "Postal address",
        "Reference link for a resource",
        "Referenced resource",
        "Selection criteria for a parameter",
        "Unified root wrapper for catalog or profile content" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ) ;
    sh:property [ sh:class linkml:Any ;
            sh:description "Back-matter references and resources" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path sp-800-53:back_matter ],
        [ sh:datatype xsd:string ;
            sh:description "UUID for profile, metadata, or resource element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:uuid ],
        [ sh:datatype xsd:string ;
            sh:description "Citation text" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:text ],
        [ sh:datatype xsd:string ;
            sh:description "Last modification timestamp" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path sp-800-53:last_modified ],
        [ sh:class linkml:Any ;
            sh:description "Include-controls selectors" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path sp-800-53:include_controls ],
        [ sh:datatype xsd:string ;
            sh:description "Link or resource reference" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:href ],
        [ sh:class sp-800-53:ControlGroup ;
            sh:description "List of control groups in the catalog" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path sp-800-53:groups ],
        [ sh:class linkml:Any ;
            sh:description "Citation details for a resource" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path sp-800-53:citation ],
        [ sh:datatype xsd:string ;
            sh:description "UUID for profile, metadata, or resource element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:uuid ],
        [ sh:class linkml:Any ;
            sh:description "Profile and Catalog metadata" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path sp-800-53:metadata ],
        [ sh:class linkml:Any ;
            sh:description "Back-matter resources" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path sp-800-53:resources ],
        [ sh:class sp-800-53:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path sp-800-53:links ],
        [ sh:datatype xsd:string ;
            sh:description "UUID for profile, metadata, or resource element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:uuid ],
        [ sh:datatype xsd:string ;
            sh:description "Link or resource reference" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:href ],
        [ sh:datatype xsd:string ;
            sh:description "Supplemental remarks" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path sp-800-53:remarks ],
        [ sh:datatype xsd:boolean ;
            sh:description "Keep source order and content during merge" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:as_is ],
        [ sh:datatype xsd:string ;
            sh:description "Media type for a resource link" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path sp-800-53:media_type ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path sp-800-53:version ],
        [ sh:datatype xsd:string ;
            sh:description "Short display name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path sp-800-53:short_name ],
        [ sh:class linkml:Any ;
            sh:description "Postal addresses" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path sp-800-53:addresses ],
        [ sh:class linkml:Any ;
            sh:description "Back-matter references and resources" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path sp-800-53:back_matter ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path sp-800-53:version ],
        [ sh:class sp-800-53:Role ;
            sh:description "Roles used in metadata" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path sp-800-53:roles ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:title ],
        [ sh:datatype xsd:string ;
            sh:description "Assigned role identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:role_id ],
        [ sh:class linkml:Any ;
            sh:description "Root catalog payload" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path sp-800-53:catalog ],
        [ sh:datatype xsd:string ;
            sh:description "Party type" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path sp-800-53:type ],
        [ sh:class linkml:Any ;
            sh:description "Resource links" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path sp-800-53:rlinks ],
        [ sh:datatype xsd:string ;
            sh:description "Address lines" ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path sp-800-53:addr_lines ],
