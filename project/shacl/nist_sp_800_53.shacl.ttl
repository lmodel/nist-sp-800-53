            sh:order 0 ;
            sh:path nist_sp_800_53:uuid ],
        [ sh:datatype xsd:string ;
            sh:description "UUID for profile, metadata, or resource element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_53:uuid ],
        [ sh:datatype xsd:string ;
