    rdfs:label "CatalogElementClassValue" ;
    rdfs:comment "Allowed values for element-level class values" ;
    owl:unionOf ( <https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#family> <https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#SP800-53> <https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#SP800-53-enhancement> <https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#assessment-objective> ) ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> ;
    linkml:permissible_values <https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#SP800-53>,
        <https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#SP800-53-enhancement>,
        <https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#assessment-objective>,
        <https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#family> .

nist_sp_800_53:IdentifiedElement a owl:Class ;
    rdfs:label "IdentifiedElement" ;
    rdfs:comment "A catalog element with required id and optional title/class" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:CatalogElementClassValue ;
            owl:onProperty nist_sp_800_53:_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:label ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:_class ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:_class ],
        nist_sp_800_53:CatalogElement ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:_class a owl:DatatypeProperty ;
    rdfs:label "_class" ;
    rdfs:comment "Classification of a catalog element or property" ;
    skos:exactMatch oscal_catalog:_class ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> ;
    skos:prefLabel "class" .

nist_sp_800_53:back_matter a owl:ObjectProperty ;
    rdfs:label "back-matter" ;
    rdfs:comment "Back-matter references and resources" ;
    rdfs:range nist_sp_800_53:BackMatter ;
    skos:altLabel "back_matter" ;
    skos:exactMatch oscal_catalog:back-matter ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

