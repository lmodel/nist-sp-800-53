    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:Control a owl:Class ;
    rdfs:label "Control" ;
    rdfs:comment "A security control" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Parameter ;
            owl:onProperty nist_sp_800_53:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ControlEnhancement ;
            owl:onProperty nist_sp_800_53:controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:params ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:controls ],
        nist_sp_800_53:IdentifiedElement ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:ControlEnhancement a owl:Class ;
    rdfs:label "ControlEnhancement" ;
    rdfs:comment "An enhancement to a control" ;
