    rdfs:label "SP800-53" ;
    rdfs:subClassOf nist_sp_800_53:CatalogElementClassValue .

<https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#SP800-53-enhancement> a owl:Class ;
