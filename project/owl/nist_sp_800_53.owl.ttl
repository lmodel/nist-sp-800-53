@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix nist_sp_800_53: <https://w3id.org/lmodel/nist-sp-800-53/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/nist-sp-800-53.owl.ttl> a owl:Ontology ;
    rdfs:label "NIST-SP-800-53" ;
    dcterms:source <https://doi.org/10.6028/NIST.SP.800-53r5> ;
    pav:version "5.2.0" ;
    rdfs:comment "Electronic (LinkML) Version of NIST SP 800-53 Rev 5 Controls and SP 800-53A Rev 5 Assessment Procedures " .

nist_sp_800_53:Catalog a owl:Class ;
    rdfs:label "Catalog" ;
    rdfs:comment "Top-level wrapper that mirrors OSCAL catalog shape" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:catalog ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:catalog ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:CatalogBody ;
            owl:onProperty nist_sp_800_53:catalog ] ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:ProfileDocument a owl:Class ;
    rdfs:label "ProfileDocument" ;
    rdfs:comment "Top-level wrapper for OSCAL profile files" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ProfileBody ;
            owl:onProperty nist_sp_800_53:profile ] ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:SP80053Document a owl:Class ;
    rdfs:label "SP80053Document" ;
    rdfs:comment "Unified root wrapper for catalog or profile content" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:CatalogBody ;
            owl:onProperty nist_sp_800_53:catalog ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ProfileBody ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:catalog ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:catalog ] ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:CatalogElement a owl:Class ;
    rdfs:label "CatalogElement" ;
    rdfs:comment "Base class for catalog elements" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Property ;
            owl:onProperty nist_sp_800_53:props ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:props ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:parts ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Part ;
            owl:onProperty nist_sp_800_53:parts ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:links ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Link ;
            owl:onProperty nist_sp_800_53:links ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:id ] ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:Address a owl:Class ;
    rdfs:label "Address" ;
    rdfs:comment "Postal address" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:postal_code ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:city ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:city ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:postal_code ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:state ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:addr_lines ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:state ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:postal_code ],
        [ a owl:Restriction ;
