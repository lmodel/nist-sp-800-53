    owl:unionOf ( <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#family> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#control> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#control_enhancement> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#control_statement> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#discussion> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#odp> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#odp_type> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#odp_statement> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#examine> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#interview> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#test> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#determination> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#withdraw_reason> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#reference> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#security_baseline> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#privacy_baseline> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#sort> <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#control_name_sort> ) ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> ;
    linkml:permissible_values <https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#control>,
