@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix nist_sp_800_53: <https://w3id.org/lmodel/nist-sp-800-53/> .
@prefix oscal_catalog: <https://w3id.org/lmodel/oscal_catalog/> .
@prefix oscal_profile: <https://w3id.org/lmodel/oscal_profile/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/nist-sp-800-53.owl.ttl> a owl:Ontology ;
    rdfs:label "NIST-SP-800-53" ;
    dcterms:source <https://doi.org/10.6028/NIST.SP.800-53r5> ;
    pav:version "5.2.0" ;
    rdfs:comment "Electronic (LinkML) Version of NIST SP 800-53 Rev 5 Controls and SP 800-53A Rev 5 Assessment Procedures " .

nist_sp_800_53:CPRTDocument a owl:Class ;
    rdfs:label "CPRTDocument" ;
    rdfs:comment "Semantic class for NIST CPRT (Cybersecurity and Privacy Reference Tool) export documents covering SP 800-53, SP 800-53A, and SP 800-53B. Validate with: linkml validate -C SP80053Document -s <schema> <file.json>" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:response ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:response ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:CPRTResponse ;
            owl:onProperty nist_sp_800_53:response ] ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:Catalog a owl:Class ;
    rdfs:label "Catalog" ;
    rdfs:comment "Top-level wrapper that mirrors OSCAL catalog shape" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:catalog ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:CatalogBody ;
            owl:onProperty nist_sp_800_53:catalog ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:catalog ] ;
    skos:closeMatch oscal_catalog:CatalogDocument ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:ProfileDocument a owl:Class ;
    rdfs:label "ProfileDocument" ;
    rdfs:comment "Top-level wrapper for OSCAL profile files" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ProfileBody ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:profile ] ;
    skos:exactMatch oscal_profile:ProfileDocument ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:SP80053Document a owl:Class ;
    rdfs:label "SP80053Document" ;
    rdfs:comment "Unified root wrapper for catalog, profile, or CPRT content" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:CatalogBody ;
            owl:onProperty nist_sp_800_53:catalog ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:catalog ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ProfileBody ;
            owl:onProperty nist_sp_800_53:profile ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:catalog ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:response ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:response ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:CPRTResponse ;
            owl:onProperty nist_sp_800_53:response ] ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:CatalogElement a owl:Class ;
    rdfs:label "CatalogElement" ;
    rdfs:comment "Base class for catalog elements" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Link ;
            owl:onProperty nist_sp_800_53:links ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:parts ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Property ;
            owl:onProperty nist_sp_800_53:props ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Part ;
            owl:onProperty nist_sp_800_53:parts ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:links ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:props ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:id ],
        nist_sp_800_53:IdentifiedElement ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:Address a owl:Class ;
    rdfs:label "Address" ;
    rdfs:comment "Postal address" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:city ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:city ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:postal_code ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:state ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:addr_lines ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:postal_code ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:city ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:postal_code ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:state ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:addr_lines ] ;
    skos:closeMatch oscal_catalog:Address ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#control> a owl:Class ;
    rdfs:label "control" ;
    rdfs:comment "Top-level security or privacy control (e.g. AC-1)" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#control_enhancement> a owl:Class ;
    rdfs:label "control_enhancement" ;
    rdfs:comment "Control enhancement (e.g. AC-1(1))" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#control_name_sort> a owl:Class ;
    rdfs:label "control_name_sort" ;
    rdfs:comment "Sort-order key for control name ordering" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#control_statement> a owl:Class ;
    rdfs:label "control_statement" ;
    rdfs:comment "Normative control statement text" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#determination> a owl:Class ;
    rdfs:label "determination" ;
    rdfs:comment "Assessment determination criterion" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#discussion> a owl:Class ;
    rdfs:label "discussion" ;
    rdfs:comment "Non-normative discussion text for a control" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#examine> a owl:Class ;
    rdfs:label "examine" ;
    rdfs:comment "SP 800-53A Examine assessment objective" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#family> a owl:Class ;
    rdfs:label "family" ;
    rdfs:comment "SP 800-53 control family (e.g. AC, AU)" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#interview> a owl:Class ;
    rdfs:label "interview" ;
    rdfs:comment "SP 800-53A Interview assessment objective" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#odp> a owl:Class ;
    rdfs:label "odp" ;
    rdfs:comment "Organization-Defined Parameter" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#odp_statement> a owl:Class ;
    rdfs:label "odp_statement" ;
    rdfs:comment "Full ODP statement text" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#odp_type> a owl:Class ;
    rdfs:label "odp_type" ;
    rdfs:comment "ODP category (e.g. assignment, selection)" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#privacy_baseline> a owl:Class ;
    rdfs:label "privacy_baseline" ;
    rdfs:comment "Privacy baseline designation (P-HIGH / NOT SELECTED)" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#reference> a owl:Class ;
    rdfs:label "reference" ;
    rdfs:comment "Informational reference to an external publication" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#security_baseline> a owl:Class ;
    rdfs:label "security_baseline" ;
    rdfs:comment "Security baseline designation (LOW / MODERATE / HIGH / NOT SELECTED)" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#sort> a owl:Class ;
    rdfs:label "sort" ;
    rdfs:comment "Sort-order key for display purposes" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#test> a owl:Class ;
    rdfs:label "test" ;
    rdfs:comment "SP 800-53A Test assessment objective" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTElementTypeValue#withdraw_reason> a owl:Class ;
    rdfs:label "withdraw_reason" ;
    rdfs:comment "Reason a control was withdrawn from SP 800-53" ;
    rdfs:subClassOf nist_sp_800_53:CPRTElementTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTRelationshipTypeValue#incorporated_into> a owl:Class ;
    rdfs:label "incorporated_into" ;
    rdfs:comment "Denotes where a withdrawn control was incorporated into another" ;
    rdfs:subClassOf nist_sp_800_53:CPRTRelationshipTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTRelationshipTypeValue#moved_to> a owl:Class ;
    rdfs:label "moved_to" ;
    rdfs:comment "Denotes where a withdrawn control was moved to" ;
    rdfs:subClassOf nist_sp_800_53:CPRTRelationshipTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTRelationshipTypeValue#projection> a owl:Class ;
    rdfs:label "projection" ;
    rdfs:comment "Represents a relationship between two elements" ;
    rdfs:subClassOf nist_sp_800_53:CPRTRelationshipTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CPRTRelationshipTypeValue#related> a owl:Class ;
    rdfs:label "related" ;
    rdfs:comment "Denotes where a control is related to another control" ;
    rdfs:subClassOf nist_sp_800_53:CPRTRelationshipTypeValue .

<https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#SP800-53> a owl:Class ;
    rdfs:label "SP800-53" ;
    rdfs:subClassOf nist_sp_800_53:CatalogElementClassValue .

<https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#SP800-53-enhancement> a owl:Class ;
    rdfs:label "SP800-53-enhancement" ;
    rdfs:subClassOf nist_sp_800_53:CatalogElementClassValue .

<https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#assessment-objective> a owl:Class ;
    rdfs:label "assessment-objective" ;
    rdfs:subClassOf nist_sp_800_53:CatalogElementClassValue .

<https://w3id.org/lmodel/nist-sp-800-53/CatalogElementClassValue#family> a owl:Class ;
    rdfs:label "family" ;
    rdfs:subClassOf nist_sp_800_53:CatalogElementClassValue .

<https://w3id.org/lmodel/nist-sp-800-53/CatalogPropertyClassValue#sp800-53> a owl:Class ;
    rdfs:label "sp800-53" ;
    rdfs:subClassOf nist_sp_800_53:CatalogPropertyClassValue .

<https://w3id.org/lmodel/nist-sp-800-53/CatalogPropertyClassValue#sp800-53a> a owl:Class ;
    rdfs:label "sp800-53a" ;
    rdfs:subClassOf nist_sp_800_53:CatalogPropertyClassValue .

<https://w3id.org/lmodel/nist-sp-800-53/CatalogPropertyClassValue#zero-padded> a owl:Class ;
    rdfs:label "zero-padded" ;
    rdfs:subClassOf nist_sp_800_53:CatalogPropertyClassValue .

nist_sp_800_53:Citation a owl:Class ;
    rdfs:label "Citation" ;
    rdfs:comment "Citation wrapper" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:text ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:text ] ;
    skos:exactMatch linkml:Any,
        oscal_catalog:Citation ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:Control a owl:Class ;
    rdfs:label "Control" ;
    rdfs:comment "A security control" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Parameter ;
            owl:onProperty nist_sp_800_53:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ControlEnhancement ;
            owl:onProperty nist_sp_800_53:controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:params ],
        nist_sp_800_53:IdentifiedElement ;
    skos:closeMatch oscal_catalog:Control ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:ControlEnhancement a owl:Class ;
    rdfs:label "ControlEnhancement" ;
    rdfs:comment "An enhancement to a control" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Parameter ;
            owl:onProperty nist_sp_800_53:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ControlEnhancement ;
            owl:onProperty nist_sp_800_53:controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:controls ],
        nist_sp_800_53:IdentifiedElement ;
    skos:closeMatch oscal_catalog:Control ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:ExcludeControlsSelection a owl:Class ;
    rdfs:label "ExcludeControlsSelection" ;
    rdfs:comment "Selection of controls to explicitly exclude from a profile import" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:with_ids ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:matching ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:with_ids ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ControlPattern ;
            owl:onProperty nist_sp_800_53:matching ] ;
    skos:closeMatch oscal_catalog:SelectControlById ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:FlatMerge a owl:Class ;
    rdfs:label "FlatMerge" ;
    rdfs:comment "Marker object indicating flat merge strategy for profile resolution" ;
    skos:exactMatch linkml:Any,
        oscal_profile:MergeFlat ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:Guideline a owl:Class ;
    rdfs:label "Guideline" ;
    rdfs:comment "Additional prose guidance associated with a parameter" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:prose ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:prose ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:prose ] ;
    skos:exactMatch oscal_catalog:ParameterGuideline ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:ImportResource a owl:Class ;
    rdfs:label "ImportResource" ;
    rdfs:comment "Imported profile or catalog reference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:href ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ExcludeControlsSelection ;
            owl:onProperty nist_sp_800_53:exclude_controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:IncludeControlsSelection ;
            owl:onProperty nist_sp_800_53:include_controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:href ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:include_controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:exclude_controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:href ] ;
    skos:exactMatch linkml:Any,
        oscal_profile:ProfileImport ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:IncludeControlsSelection a owl:Class ;
    rdfs:label "IncludeControlsSelection" ;
    rdfs:comment "Control inclusion selector" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:ControlPattern ;
            owl:onProperty nist_sp_800_53:matching ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_53:with_ids ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:with_ids ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:matching ] ;
    skos:closeMatch oscal_catalog:SelectControlById ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:MergeRules a owl:Class ;
    rdfs:label "MergeRules" ;
    rdfs:comment "Merge configuration" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:flat ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty nist_sp_800_53:as_is ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:as_is ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:flat ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:FlatMerge ;
            owl:onProperty nist_sp_800_53:flat ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:as_is ] ;
    skos:exactMatch linkml:Any,
        oscal_profile:ProfileMerge ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-53> .

nist_sp_800_53:Party a owl:Class ;
    rdfs:label "Party" ;
    rdfs:comment "Party definition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:addresses ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_53:short_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_53:Address ;
            owl:onProperty nist_sp_800_53:addresses ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
