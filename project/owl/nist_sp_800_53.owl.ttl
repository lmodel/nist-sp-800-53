            owl:onProperty nist_sp_800_53:text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_53:text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
